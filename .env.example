# Lens Config
LENS_PORT=4000
LENS_SHARED_SECRET=<secret>
LENS_CONCURRENCY=2
LENS_KV_MAX_TTL_MS=3600000     # ceiling: 1 hour
LENS_DEDUP_TTL_S=300           # 5 min

# local proxy
PIPE_PROXY_URL=http://localhost:8787

# Redis
REDIS_URL=redis://localhost:6379

# Cloudflare KV
CF_ACCOUNT_ID=<id>
CF_KV_NAMESPACE_ID=<id>
CF_API_TOKEN=<token>

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"
